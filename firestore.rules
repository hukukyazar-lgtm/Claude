// ===============================================================
// Assumed Data Model
// ===============================================================
//
// This security rules file assumes the following data structures:
//
// Collection: users
// Document ID: {userId} (matches Firebase Auth UID)
// Fields:
//   - level: number (required)
//   - coins: number (required)
//   - stars: number (required)
//   - hearts: number (required)
//   - hintsFreeze: number (optional)
//   - hintsReveal: number (optional)
//   - difficultyFactor: number (optional)
//   - updatedAt: timestamp/number (optional)
//
// Collection: leaderboard
// Document ID: {userId} (matches Firebase Auth UID)
// Fields:
//   - name: string (required)
//   - score: number (required)
//   - photo: string (optional)
//   - level: number (required)
//   - updatedAt: timestamp/number (optional)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "hukukyazar@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUserStats(data) {
      return data.level is number && data.level >= 0 &&
             data.coins is number && data.coins >= 0 &&
             data.stars is number && data.stars >= 0 &&
             data.hearts is number && data.hearts >= 0;
    }

    function isValidLeaderboardEntry(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.score is number && data.score >= 0 &&
             data.level is number && data.level >= 0;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    function isUnchanged(field) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny([field]);
    }

    function isValidEconomyUpdate() {
      return (request.resource.data.coins - resource.data.coins <= 1500) &&
             (request.resource.data.stars - resource.data.stars <= 3) &&
             (request.resource.data.level - resource.data.level <= 1) &&
             request.resource.data.coins >= resource.data.coins &&
             request.resource.data.stars >= resource.data.stars &&
             request.resource.data.level >= resource.data.level;
    }

    function isValidScoreUpdate(userId, resourceData) {
      return resourceData.score == (get(/databases/$(database)/documents/users/$(userId)).data.level * 1000) + 
                                    (get(/databases/$(database)/documents/users/$(userId)).data.stars * 50) + 
                                    (get(/databases/$(database)/documents/users/$(userId)).data.coins / 10) &&
             resourceData.level == get(/databases/$(database)/documents/users/$(userId)).data.level &&
             resourceData.name is string &&
             resourceData.name.size() > 0;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && hasRequiredFields(['level', 'coins', 'stars', 'hearts']) && isValidUserStats(request.resource.data);
      allow update: if isOwner(userId) && isValidEconomyUpdate();
      allow delete: if isAdmin();
    }

    match /leaderboard/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isOwner(userId) && isValidScoreUpdate(userId, request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
